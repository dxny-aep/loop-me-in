{
  "version": 2,
  "name": "loop-me-in",
  "env": [
    "ANTHROPIC_API_KEY",
    "EVENTBRITE_API_KEY"
  ],
  "functions": {
    "serve.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/serve.js"
    },
    {
      "source": "/:path*",
      "destination": "/dashboard-with-refresh.html"
    }
  ]
}
